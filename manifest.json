{
	"name": "LeanRabbook",
	"version": "3.1",
	"description": "Auto Parser of Novel",
	"short_name": "LRabook",
	"manifest_version": 3,
	"icons": {
		"48": "src/images/icon.png",
		"128": "src/images/icon.png"
	},
	"action": {
		"default_icon": "src/images/icon.png",
		"default_popup": "src/index.html",
		"default_title": "RabbookLean"
	},
	"background": {
		"service_worker": "src/background.js"
	},
	"externally_connectable": {
		"ids": [
			"ipmdlkljiioildfgddmmkfdmdfehboal",
			"fgkgjmmeoaojnhkeiebbibgbodikmgoe",
			"ablggfkhbegbnlgjbleoklekinmglnia"
		]
	},
	"sandbox": {
		"pages": [
			"src/sandbox.html"
		]
	},
	"content_security_policy": {
		"sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval'; child-src 'self';"
	},
	"web_accessible_resources": [
		{
			"resources": [
				"src/font/fonts/icomoon.eot",
				"src/font/fonts/icomoon.ttf",
				"src/font/fonts/icomoon.woff",
				"src/font/fonts/icomoon.svg",
				"src/font/font.ttf",
				"src/font/style.css",
				"src/main.css",
				"src/main.js",
				"src/pre-main.js",
				"src/details.html",
				"src/details.css",
				"src/details.js",
				"src/html-handling.js",
				"src/pageRewrite.js",
				"src/jquery.js",
				"src/reader-frame.html",
				"src/reader-frame.js",
				"src/sandbox.html",
				"src/sandbox.js"
			],
			"matches": [
				"<all_urls>"
			]
		}
	],
	"host_permissions": [
		"<all_urls>"
	],
	"permissions": [
		"tabs",
		"scripting",
		"storage",
		"activeTab"
	]
}